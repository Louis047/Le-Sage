# Supabase Authentication (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Semantic Scholar API Key (Required for academic search)
# Get your API key from: https://www.semanticscholar.org/product/api
# Rate limit: 1 request per second across all endpoints
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# LLM Provider Settings
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
HF_TOKEN=your_huggingface_token_if_using_hf

# Backend API URL for frontend (adjust for production)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
